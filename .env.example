PORT=3000
API_KEY=replace_with_strong_random_string

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Internal web server lookup (over private VLAN)
WEB_SERVER_INTERNAL_URL=http://<private-vlan-ip>:3001/internal/user-lookup
INTERNAL_SECRET=replace_with_strong_random_string

# OTP delivery webhook
WEBHOOK_URL=https://your-demo-webhook-url.com/otp

# OTP config
OTP_TTL_SECONDS=300
OTP_LENGTH=6
